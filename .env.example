IOT_CONNECTION_STRING=HostName=<your-iothub>.azure-devices.net;DeviceId=<your-device-id>;SharedAccessKey=<your-device-key>
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-storage-account>;AccountKey=<your-account-key>;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=patient-monitoring
DEVICE_ID=rpi5-patient-monitor
PIR_GPIO_PIN=17
INACTIVITY_TIMEOUT_SECONDS=60
RECORDING_DURATION_SECONDS=5
VIDEO_DIRECTORY=recordings
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FRAMERATE=30
LOG_LEVEL=INFO